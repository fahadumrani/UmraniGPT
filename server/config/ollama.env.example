# ============================================================
# UmraniGPT — Connection Settings
# This is the ONLY file most people need to touch to get
# chatting working. Copy it to "ollama.env" (same folder) and
# fill in the two values below. Everything else lives in the
# main server/.env (accounts, sessions, social login, etc).
# ============================================================

# Where Ollama is running. This is never sent to the browser —
# users and the admin dashboard only ever see "Connected" /
# "Offline", never this address.
OLLAMA_URL=http://localhost:11434

# Optional. Lets you call the admin API directly (from a script,
# a monitoring tool, cron job, etc.) using a header instead of
# logging in through the browser:
#   curl -H "X-API-Key: <this value>" https://your-backend/api/admin/dashboard
# Leave this blank to disable — normal browser login is not
# affected either way.
BACKEND_API_KEY=
